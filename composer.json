{
    "name": "marko/media",
    "description": "Media management package for Marko Framework",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "marko/core": "self.version",
        "marko/filesystem": "self.version",
        "marko/database": "self.version",
        "marko/validation": "self.version",
        "marko/config": "self.version"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "marko/testing": "self.version"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Media\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Media\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
